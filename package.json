{
  "name": "shoe-makers",
  "type": "module",
  "private": true,
  "scripts": {
    "wiki": "OCTOWIKI_DIR=$PWD/wiki PORT=4570 bun run node_modules/octowiki/src/index.ts",
    "test": "bun test",
    "dev": "bun run src/index.ts",
    "tick": "bun run src/index.ts",
    "init": "bun run src/run-init.ts",
    "setup": "bun run src/setup.ts",
    "shift": "bun run src/shift.ts",
    "task:status": "bun run src/task.ts status",
    "task:done": "bun run src/task.ts done",
    "task:fail": "bun run src/task.ts fail",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5 || ^6"
  },
  "dependencies": {
    "octoclean": "github:maxthelion/octoclean",
    "octowiki": "github:maxthelion/octowiki"
  }
}
